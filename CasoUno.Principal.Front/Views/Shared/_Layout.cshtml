<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - softMaterial</title>
    <!-- Google Fonts: Roboto -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <!-- Bootstrap 5.3.x CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <!-- CSS personalizado -->
    <link href="~/Content/site-layout.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Sidebar (fondo blanco) -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-chart-pie"></i> <span>softMaterial</span>
        </div>
        <nav class="sidebar-nav">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link active" href="#"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-shopping-cart"></i> Orders</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-box"></i> Products</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-users"></i> Customers</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-chart-bar"></i> Reports</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-cog"></i> Settings</a>
                </li>
            </ul>
        </nav>
        <div class="sidebar-footer">
            <div class="user-info">
                <img src="~/Images/avatar.jpeg" alt="Avatar" class="rounded-circle" />
                <div>
                    <span class="user-name">@User.Identity.Name</span>
                    <span class="user-role">Admin</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- Contenido principal -->
    <div class="main-content" id="mainContent">
        <!-- Header superior -->
        <header class="top-header">
            <div class="d-flex align-items-center">
                <button class="btn btn-hamburger" id="hamburgerBtn" type="button">
                    <i class="fas fa-bars"></i>
                </button>
                <h5 class="mb-0 ms-2">@ViewData["Title"]</h5>
            </div>
            <div class="header-actions">
                <i class="fas fa-bell"></i>
                <i class="fas fa-user-circle"></i>
            </div>
        </header>

        <!-- Cuerpo de página -->
        <main class="page-content">
            @RenderBody()
        </main>
    </div>

    <!-- Overlay para móvil -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <script src="~/Scripts/bootstrap.min.js"></script>

    <!-- Bootstrap 5.3.x JS Bundle -->
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <!-- JavaScript personalizado -->
    <script src="~/Scripts/site-layout.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>